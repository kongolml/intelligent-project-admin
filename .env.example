# ─── LOCAL DEV ─────────────────────────────────────────────────────────────────
# Copy this file to .env for `npm run dev`

DATABASE_URL=
PAYLOAD_SECRET=

DIGITALOCEAN_SPACE_REGION=fra1
DIGITALOCEAN_SPACE_ENDPOINT=https://fra1.digitaloceanspaces.com
DIGITALOCEAN_SPACE_BUCKET=
DIGITALOCEAN_SPACE_HOST=
S3_ACCESS_KEY=
S3_SECRET_KEY=

NEXT_PUBLIC_SERVER_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
PAYLOAD_WEBHOOK_SECRET=


# ─── GitHub Actions secrets ─────────────────────────────────────────────────────
# Settings → Secrets and variables → Actions
#
# NEXT_PUBLIC_SERVER_URL   public CMS URL — baked into the JS bundle at build time
# PAYLOAD_SECRET           used at build time and runtime
# DATABASE_URL             production MongoDB URI
# S3_ACCESS_KEY            DigitalOcean Spaces key
# S3_SECRET_KEY            DigitalOcean Spaces secret
# PAYLOAD_WEBHOOK_SECRET   webhook HMAC secret
# DROPLET_SSH_KEY          SSH private key for the droplet
# DROPLET_USER             SSH login user
# DROPLET_HOST             droplet IP or hostname
# DROPLET_SSH_PORT         SSH port
